# demo/.env.demo — overlay for running a ZERO-DEPENDENCY local demo server.
# Source these into the server process only (never mutate your real .env).
# Usage (bash):   set -a; source demo/.env.demo; set +a; uvicorn app.main:app --port 8000
# Usage (pwsh):   Get-Content demo/.env.demo | ... (see README)
#
# SQLite backend (no Postgres) + development env (enables demo seams).
# Redis is optional: get_checkpointer() falls back to an in-memory saver.
ENVIRONMENT=development
DATABASE_URL=sqlite:///./demo.db
REDIS_URL=redis://localhost:6379/0

# LLM: set your OpenRouter key to exercise the real model (happy_path, etc.).
# Leave LLM_ENABLED=false for a fully offline run (llm_dead behavior for all).
LLM_ENABLED=false
# LLM_API_KEY=sk-or-...
# LLM_MODEL=qwen/qwen-2.5-7b-instruct

# ── Per-scenario overrides (uncomment ONE set, restart the server) ──
# enrichment_down:
# ENRICHMENT_API_URL=http://127.0.0.1:9
# llm_malformed:   LLM_ENABLED=true + LLM_API_KEY=... plus:
# LLM_FORCE_MALFORMED=true
# low_confidence:  LLM_ENABLED=true + LLM_API_KEY=... plus:
# LLM_FORCE_CONFIDENCE=0.40
