# ============================================================
# APPLICATION SETTINGS
# ============================================================
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
REFRESH_SECRET_KEY=change-this-to-a-different-long-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://agentuser:agentpassword@localhost:5432/leadagentdb
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=agentpassword
POSTGRES_DB=leadagentdb

# ============================================================
# REDIS (State Checkpointing + Cache)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# AI / LLM (OpenAI-compatible client → OpenRouter, open-weight first)
# ============================================================
# OpenRouter speaks the OpenAI Chat Completions API.
LLM_BASE_URL=https://openrouter.ai/api/v1
# Open-weight instruct model on OpenRouter. Default is a FREE tier; for higher
# reliability under load, use a paid model (e.g. qwen/qwen-2.5-7b-instruct).
LLM_MODEL=openai/gpt-oss-20b:free
LLM_API_KEY=sk-or-your-openrouter-key-here
LLM_TIMEOUT_SECONDS=20
LLM_ENABLED=true
# Path to the system prompt file (never inlined in code).
AGENT_PROMPT_PATH=AGENTS.md
# Demo-only: force the first LLM response to be malformed to film the
# self-correction / fallback path. Leave false in normal operation.
LLM_FORCE_MALFORMED=false

# ── DEPRECATED (still read for backward compat; prefer LLM_* above) ──
# If LLM_API_KEY is unset, LLM_API_KEY falls back to OPENAI_API_KEY.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ============================================================
# EXTERNAL TOOL APIS
# ============================================================
ENRICHMENT_API_URL=https://api.example-enrichment.com/v1/company
CRM_API_URL=https://api.your-crm.com/v1
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ============================================================
# EMAIL (SMTP) — for scheduled follow-up emails
# Leave EMAIL_ENABLED=false to run in DRY-RUN mode (logs instead of sending);
# no SMTP creds needed. Set it true + fill SMTP_* to send real mail.
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true,
#            SMTP_USERNAME=you@gmail.com, SMTP_PASSWORD=<16-char App Password>
# ============================================================
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=Lead Flow AI <no-reply@example.com>

# ============================================================
# SCHEDULER (background dispatcher for scheduled emails)
# ============================================================
SCHEDULER_ENABLED=true
EMAIL_DISPATCH_INTERVAL_SECONDS=60
EMAIL_MAX_ATTEMPTS=3

# ============================================================
# LEAD IMPORT (bulk file/paste + inbound-email webhook)
# ============================================================
# Max rows per file/paste import.
MAX_IMPORT_ROWS=500
# Shared secret for the inbound-email webhook (POST /v1/leads/inbound-email).
# Leave BLANK to keep the webhook disabled (returns 404). Set it, then point a
# SendGrid/Mailgun Inbound Parse route at the URL with ?token=<this value>.
INBOUND_EMAIL_TOKEN=
