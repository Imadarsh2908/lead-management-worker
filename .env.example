# ============================================================
# APPLICATION SETTINGS
# ============================================================
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
REFRESH_SECRET_KEY=change-this-to-a-different-long-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://agentuser:agentpassword@localhost:5432/leadagentdb
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=agentpassword
POSTGRES_DB=leadagentdb

# ============================================================
# REDIS (State Checkpointing + Cache)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# AI / LLM KEYS
# (Only one is needed depending on model choice)
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ============================================================
# EXTERNAL TOOL APIS
# ============================================================
ENRICHMENT_API_URL=https://api.example-enrichment.com/v1/company
CRM_API_URL=https://api.your-crm.com/v1
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
