# Copy to .env (local dev) or .env.production (before building for deploy),
# then edit. Vite only exposes variables prefixed with VITE_ to client code,
# and reads them at BUILD time — changing this after `npm run build` requires
# rebuilding, not just restarting the server.

# Base URL of the backend API (no trailing slash). Defaults to
# http://localhost:8000 in code if this is unset, for local dev convenience.
VITE_API_URL=http://localhost:8000
